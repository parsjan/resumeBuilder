# =============================================================================
# AI Resume Builder — Backend Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values for your environment.
# Never commit .env to version control.
#
# Spring Boot reads these at startup via ${VAR_NAME} placeholders in
# src/main/resources/application.yml.
# =============================================================================


# -----------------------------------------------------------------------------
# Database (PostgreSQL)
# -----------------------------------------------------------------------------
DB_HOST=localhost
DB_PORT=5432
DB_NAME=ai_resume_db
DB_USERNAME=postgres
DB_PASSWORD=your_postgres_password


# -----------------------------------------------------------------------------
# JWT
# Generate a secure random secret:
#   openssl rand -base64 64
# -----------------------------------------------------------------------------
JWT_SECRET=CHANGE_ME_use_a_256bit_or_longer_random_secret_in_production
JWT_EXPIRATION_MS=86400000          # 1 day  (milliseconds)
JWT_REFRESH_EXPIRATION_MS=604800000 # 7 days (milliseconds)


# -----------------------------------------------------------------------------
# OpenAI
# Get your key at https://platform.openai.com/api-keys
# -----------------------------------------------------------------------------
OPENAI_API_KEY=sk-your-openai-api-key-here


# -----------------------------------------------------------------------------
# Google OAuth2
# Create credentials at https://console.cloud.google.com/apis/credentials
# Authorised redirect URI must include:
#   http://localhost:8080/api/v1/login/oauth2/callback/google  (local dev)
# -----------------------------------------------------------------------------
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret


# -----------------------------------------------------------------------------
# GitHub OAuth2
# Create an OAuth App at https://github.com/settings/developers
# Authorisation callback URL:
#   http://localhost:8080/api/v1/login/oauth2/callback/github  (local dev)
# -----------------------------------------------------------------------------
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret


# -----------------------------------------------------------------------------
# OAuth2 — post-login redirect (sent back to the frontend)
# -----------------------------------------------------------------------------
OAUTH2_REDIRECT_URI=http://localhost:3000/oauth2/callback


# -----------------------------------------------------------------------------
# AWS / S3
# The IAM user/role needs s3:PutObject, s3:GetObject, s3:DeleteObject on the bucket.
# -----------------------------------------------------------------------------
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_REGION=us-east-1
AWS_S3_BUCKET=ai-resume-builder-files
S3_SIGNED_URL_EXPIRY_MINUTES=60


# -----------------------------------------------------------------------------
# CORS
# Comma-separated list of allowed frontend origins.
# No trailing slash, no wildcards in production.
# -----------------------------------------------------------------------------
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
